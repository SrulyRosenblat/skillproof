{
  "name": "Order Confirmation Automation",
  "nodes": [
    {
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "={{$json.user_id}}/webhook",
        "responseMode": "onReceived"
      }
    },
    {
      "id": "2",
      "name": "Format Order",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [460, 300],
      "parameters": {
        "fields": [
          {"name": "order_id", "value": "={{$json.order_id}}", "type": "string"},
          {"name": "customer_name", "value": "={{ {{$json.body.customer_name}} }}", "type": "string"},
          {"name": "status", "value": "={{$json.body.status}}", "type": "string"},
          {"name": "source", "value": "webhook-order-flow", "type": "string"}
        ]
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [{"node": "Format Order", "type": "main", "index": 0}]
      ]
    }
  }
}
