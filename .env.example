# Copy to .env (gitignored). Loaded automatically at startup.

# Required for evaluation runs (`skillproof run`) and the default
# `embedding.provider: openrouter` (`skillproof cluster`)
OPENROUTER_API_KEY=

# Only needed if you switch to `embedding.provider: openai`
OPENAI_API_KEY=

# The Codex CLI (`skillproof generate`) uses its own auth: run `codex login` once.
